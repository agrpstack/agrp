{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://registack.eu/schemas/agrp-core.strict.v0.3.schema.json",
  "title": "AGRP Strict Core Profile v0.3",
  "type": "object",
  "required": [
    "agrp_version",
    "agrp_code",
    "reason",
    "issuer",
    "timestamp",
    "correlation_id",
    "details"
  ],
  "properties": {
    "agrp_version": {
      "type": "string",
      "const": "0.3"
    },
    "agrp_code": {
      "type": "integer",
      "enum": [601, 602, 603, 604, 605, 606, 607, 608, 609, 610, 611, 612, 613, 614, 615]
    },
    "reason": {
      "type": "string",
      "enum": [
        "identity_required",
        "payment_required",
        "capability_missing",
        "policy_violation",
        "human_approval_required",
        "governance_rate_limit",
        "scope_mismatch",
        "intent_conflict",
        "delegation_not_allowed",
        "remediation_required",
        "incident_ticket_created",
        "rerouted_to_specialist_agent",
        "certification_expired",
        "trust_level_insufficient",
        "execution_frozen"
      ]
    },
    "issuer": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1
    },
    "http_status": {
      "type": "integer",
      "minimum": 100,
      "maximum": 599
    },
    "details": {
      "type": "object"
    },
    "signature": {
      "type": "object",
      "required": ["profile", "alg", "kid", "value"],
      "properties": {
        "profile": { "type": "string" },
        "alg": { "type": "string" },
        "kid": { "type": "string" },
        "value": { "type": "string" },
        "nonce": { "type": "string" },
        "created": { "type": "string", "format": "date-time" },
        "expires": { "type": "string", "format": "date-time" },
        "canonicalization": { "type": "string" },
        "cert_chain_ref": { "type": "string" }
      },
      "additionalProperties": false
    },
    "extensions": {
      "type": "object",
      "propertyNames": {
        "pattern": "^(?:[A-Za-z0-9-]+\\.)+[A-Za-z0-9-]+$|^https://.+$"
      },
      "additionalProperties": {
        "type": "object"
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "agrp_code": { "const": 601 } }, "required": ["agrp_code"] },
      "then": {
        "properties": {
          "reason": { "const": "identity_required" },
          "details": {
            "type": "object",
            "required": ["identity_provider", "required_identity_assurance"],
            "properties": {
              "identity_provider": { "type": "string" },
              "required_identity_assurance": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": { "properties": { "agrp_code": { "const": 602 } }, "required": ["agrp_code"] },
      "then": {
        "properties": {
          "reason": { "const": "payment_required" },
          "details": {
            "type": "object",
            "required": ["budget_id", "required_amount", "payment_authority"],
            "properties": {
              "budget_id": { "type": "string" },
              "required_amount": {
                "type": "object",
                "required": ["currency", "value"],
                "properties": {
                  "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
                  "value": { "type": "string" }
                },
                "additionalProperties": false
              },
              "payment_authority": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": { "properties": { "agrp_code": { "const": 603 } }, "required": ["agrp_code"] },
      "then": {
        "properties": {
          "reason": { "const": "capability_missing" },
          "details": {
            "type": "object",
            "required": ["required_capability"],
            "properties": {
              "required_capability": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": { "properties": { "agrp_code": { "const": 604 } }, "required": ["agrp_code"] },
      "then": {
        "properties": {
          "reason": { "const": "policy_violation" },
          "details": {
            "type": "object",
            "required": ["policy_reference"],
            "properties": {
              "policy_reference": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": { "properties": { "agrp_code": { "const": 605 } }, "required": ["agrp_code"] },
      "then": {
        "properties": {
          "reason": { "const": "human_approval_required" },
          "details": {
            "type": "object",
            "required": ["approval_role"],
            "properties": {
              "approval_role": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": { "properties": { "agrp_code": { "const": 606 } }, "required": ["agrp_code"] },
      "then": {
        "properties": {
          "reason": { "const": "governance_rate_limit" },
          "details": {
            "type": "object",
            "required": ["limit_scope", "retry_after_seconds", "threshold_type"],
            "properties": {
              "limit_scope": { "type": "string" },
              "retry_after_seconds": { "type": "integer", "minimum": 0 },
              "threshold_type": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": { "properties": { "agrp_code": { "const": 607 } }, "required": ["agrp_code"] },
      "then": {
        "properties": {
          "reason": { "const": "scope_mismatch" },
          "details": {
            "type": "object",
            "required": ["declared_scope", "requested_scope"],
            "properties": {
              "declared_scope": { "type": "string" },
              "requested_scope": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": { "properties": { "agrp_code": { "const": 608 } }, "required": ["agrp_code"] },
      "then": {
        "properties": {
          "reason": { "const": "intent_conflict" },
          "details": {
            "type": "object",
            "required": ["declared_intent", "inferred_intent"],
            "properties": {
              "declared_intent": { "type": "string" },
              "inferred_intent": { "type": "string" },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": { "properties": { "agrp_code": { "const": 609 } }, "required": ["agrp_code"] },
      "then": {
        "properties": {
          "reason": { "const": "delegation_not_allowed" },
          "details": {
            "type": "object",
            "required": ["delegation_target", "delegation_policy"],
            "properties": {
              "delegation_target": { "type": "string" },
              "delegation_policy": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": { "properties": { "agrp_code": { "const": 610 } }, "required": ["agrp_code"] },
      "then": {
        "properties": {
          "reason": { "const": "remediation_required" },
          "details": {
            "type": "object",
            "required": ["remediation_actions"],
            "properties": {
              "remediation_actions": { "type": "array", "items": { "type": "string" } },
              "incident_reference": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": { "properties": { "agrp_code": { "const": 611 } }, "required": ["agrp_code"] },
      "then": {
        "properties": {
          "reason": { "const": "incident_ticket_created" },
          "details": {
            "type": "object",
            "required": ["ticket_id"],
            "properties": {
              "ticket_id": { "type": "string" },
              "incident_reference": { "type": "string" },
              "ticket_queue": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": { "properties": { "agrp_code": { "const": 612 } }, "required": ["agrp_code"] },
      "then": {
        "properties": {
          "reason": { "const": "rerouted_to_specialist_agent" },
          "details": {
            "type": "object",
            "required": ["specialist_agent_id", "specialist_capability"],
            "properties": {
              "specialist_agent_id": { "type": "string" },
              "specialist_capability": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": { "properties": { "agrp_code": { "const": 613 } }, "required": ["agrp_code"] },
      "then": {
        "properties": {
          "reason": { "const": "certification_expired" },
          "details": {
            "type": "object",
            "required": ["certificate_id", "expired_at", "required_certification"],
            "properties": {
              "certificate_id": { "type": "string" },
              "expired_at": { "type": "string", "format": "date-time" },
              "required_certification": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": { "properties": { "agrp_code": { "const": 614 } }, "required": ["agrp_code"] },
      "then": {
        "properties": {
          "reason": { "const": "trust_level_insufficient" },
          "details": {
            "type": "object",
            "required": ["required_trust_level", "actual_trust_level"],
            "properties": {
              "required_trust_level": { "type": "string" },
              "actual_trust_level": { "type": "string" },
              "trust_policy": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": { "properties": { "agrp_code": { "const": 615 } }, "required": ["agrp_code"] },
      "then": {
        "properties": {
          "reason": { "const": "execution_frozen" },
          "details": {
            "type": "object",
            "required": ["freeze_reason", "freeze_reference"],
            "properties": {
              "freeze_reason": { "type": "string" },
              "freeze_reference": { "type": "string" },
              "incident_reference": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
